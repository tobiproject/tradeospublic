# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Anthropic (Claude API) — required for KI-Analyse Engine (PROJ-4)
# Get your key at: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Web Push Notifications — generate keys: node -e "require('web-push').generateVAPIDKeys()"
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_EMAIL=mailto:your@email.com

# Email Notifications — Resend (https://resend.com, free 3000/month)
RESEND_API_KEY=re_xxxx
NOUS_FROM_EMAIL=notifications@yourdomain.com
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# Vercel Cron protection secret
CRON_SECRET=your-random-secret-here

# Supabase Service Role Key (for cron jobs — server-only, never expose to client)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
